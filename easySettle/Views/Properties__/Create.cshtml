 @model easySettle.Models.Properties

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Properties</h4>
<hr />

<div class="row">
    <div class="col-md-12">
        <form asp-action="Create" method="post">
            <ul class="nav nav-tabs" id="myTabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" id="general-tab" data-toggle="tab" href="#general" role="tab" aria-controls="general" aria-selected="true" disabled>General</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="location-tab" data-toggle="tab" href="#location" role="tab" aria-controls="location" aria-selected="false" disabled>Location</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="amenities-tab" data-toggle="tab" href="#amenities" role="tab" aria-controls="amenities" aria-selected="false" disabled>Amenities</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" id="galery-tab" data-toggle="tab" href="#galery" role="tab" aria-controls="galery" aria-selected="false" disabled>Galery</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" id="submit-tab" data-toggle="tab" href="#submit" role="tab" aria-controls="submit" aria-selected="false" disabled>Submit</a>
                </li>
            </ul>

            <div class="tab-content" id="myTabsContent">
                <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">
                    <p>Basic Info</p>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="control-label"></label>
                        <input asp-for="Description" class="form-control" required />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="RentPrice" class="control-label"></label>
                        <input asp-for="RentPrice" class="form-control" />
                        <span asp-validation-for="RentPrice" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Rooms" class="control-label"></label>
                        <input asp-for="Rooms" class="form-control" />
                        <span asp-validation-for="Rooms" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="BathRooms" class="control-label"></label>
                        <input asp-for="BathRooms" class="form-control" />
                        <span asp-validation-for="BathRooms" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Sqft" class="control-label"></label>
                        <input asp-for="Sqft" class="form-control" />
                        <span asp-validation-for="Sqft" class="text-danger"></span>
                    </div>
                    <button type="button" class="btn btn-primary next-tab" data-next="#location-tab">Next</button>
                </div>

                <div class="tab-pane fade" id="location" role="tabpanel" aria-labelledby="location-tab">
                    <p> Location info</p>
                    <div class="form-group">
                        <label asp-for="StreetName" class="control-label"></label>
                        <input asp-for="StreetName" class="form-control" />
                        <span asp-validation-for="StreetName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ZipCode" class="control-label"></label>
                        <input asp-for="ZipCode" class="form-control" />
                        <span asp-validation-for="ZipCode" class="text-danger"></span>
                    </div>


                    <div class="form-group">
                        <label asp-for="Lat" class="control-label"></label>
                        <input asp-for="Lat" class="form-control" />
                        <span asp-validation-for="Lat" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Lon" class="control-label"></label>
                        <input asp-for="Lon" class="form-control" />
                        <span asp-validation-for="Lon" class="text-danger"></span>
                    </div>

                    <button type="button" class="btn btn-secondary prev-tab" data-prev="#general-tab">Previous</button>
                    <button type="button" class="btn btn-primary next-tab" data-next="#amenities-tab">Next</button>
                </div>



                <div class="tab-pane fade" id="amenities" role="tabpanel" aria-labelledby="amenities-tab">
                    <p>Amenities</p>

                   @*  <div class="form-group">
                        <label asp-for="SelectedAmenities" class="control-label"></label>
                            @foreach (var amenity in ViewBag.AmenitiesId)
                            {
                                <div class="form-check">
                                    <input type="checkbox" name="AmenitiesId" value="@amenity.Value" class="form-check-input" />
                                    <label class="form-check-label">@amenity.Text</label>
                                </div>
                            }
                        
                        
                    </div> *@


                  @*   <div class="form-group">
                        <label asp-for="SelectedBuildingAmenities" class="control-label"></label>
                        @foreach (var buildingAmenity in ViewBag.BuildingAmenitiesId)
                        {
                            <div class="form-check">
                                <input type="checkbox" name="BuildingAmenitiesId" value="@buildingAmenity.Value" class="form-check-input" />
                                <label class="form-check-label">@buildingAmenity.Text</label>
                            </div>
                        }
                    </div>
 *@
                    <div class="form-group">
                        <label for="SelectedBuildingAmenities">Select Building Amenities:</label>
                        @foreach (var amenity in ViewBag.BuildingAmenities as List<BuildingAmenities>)
                        {
                            <div class="form-check">
                                <input type="checkbox" id="amenity_@amenity.Id" name="selectedAmenities" value="@amenity.Id" />
                                <label for="amenity_@amenity.Id">@amenity.Name</label>
                            </div>
                        }
                    </div>

                    <div class="form-group">
                        <label for="selectedAmenities">Select Amenities:</label>
                        @foreach (var amenity in ViewBag.Amenities as List<Amenities>)
                        {
                            <div class="form-check">
                                <input type="checkbox" id="amenity_@amenity.Id" name="SelectedBuildingAmenities" value="@amenity.Id" />
                                <label for="amenity_@amenity.Id">@amenity.Name</label>
                            </div>
                        }
                    </div>

                    <div class="form-group form-check">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="PetFriendly" /> @Html.DisplayNameFor(model => model.PetFriendly)
                        </label>
                    </div>


                    <div class="form-group">
                        <label asp-for="PropertyTypeId" class="control-label"></label>
                        <select asp-for="PropertyTypeId" class="form-control" asp-items="ViewBag.PropertyTypeId"></select>
                    </div>

                    <button type="button" class="btn btn-secondary prev-tab" data-prev="#location-tab">Previous</button>
                    <button type="button" class="btn btn-primary next-tab" data-next="#galery-tab">Next</button>
                </div>



                <div class="tab-pane fade" id="galery" role="tabpanel" aria-labelledby="galery-tab">
                    <p> Photo Galery</p>

                    <div id="galleryItems">
                        <div class="form-group">
                            <label asp-for="PicFile1" class="control-label"></label>
                            <input type="file" asp-for="PicFile1" class="form-control" />
                            <span asp-validation-for="PicFile1" class="text-danger"></span>
                        </div>
                    </div>



                    <div id="galleryItems">
                        <div class="form-group">
                            <label asp-for="PicFile2" class="control-label"></label>
                            <input type="file" asp-for="PicFile2" class="form-control" />
                            <span asp-validation-for="PicFile2" class="text-danger"></span>
                        </div>
                    </div>


                    <div id="galleryItems">
                        <div class="form-group">
                            <label asp-for="PicFile3" class="control-label"></label>
                            <input type="file" asp-for="PicFile3" class="form-control" />
                            <span asp-validation-for="PicFile3" class="text-danger"></span>
                        </div>
                    </div>


                    <div id="galleryItems">
                        <div class="form-group">
                            <label asp-for="PicFile4" class="control-label"></label>
                            <input type="file" asp-for="PicFile4" class="form-control" />
                            <span asp-validation-for="PicFile4" class="text-danger"></span>
                        </div>
                    </div>


                    <div id="galleryItems">
                        <div class="form-group">
                            <label asp-for="PicFile5" class="control-label"></label>
                            <input type="file" asp-for="PicFile5" class="form-control" />
                            <span asp-validation-for="PicFile5" class="text-danger"></span>
                        </div>
                    </div>


                    <button type="button" class="btn btn-secondary prev-tab" data-prev="#amenities-tab">Previous</button>
                    <button type="button" class="btn btn-primary next-tab" data-next="#submit-tab">Next</button>
                </div>



                <div class="tab-pane fade" id="submit" role="tabpanel" aria-labelledby="submit-tab">
                    <p>Publish</p>

                    <div class="form-group form-check">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="IsDeleted" /> @Html.DisplayNameFor(model => model.IsDeleted)
                        </label>
                    </div>
                    <div class="form-group form-check">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="Enable" /> @Html.DisplayNameFor(model => model.Enable)
                        </label>
                    </div>

                    <div class="form-group mt-3"><button type="submit" class="btn btn-primary">Create</button></div>
                    <button type="button" class="btn btn-secondary prev-tab" data-prev="#galery-tab">Previous</button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
    <script>
        $(function () {
            $('.next-tab').click(function () {
                var currentTab = $(this).closest('.tab-pane');
                var nextTab = $(this).data('next');

                var isValid = validateTab(currentTab);

                if (isValid) {
                    $(nextTab).tab('show');
                    $(currentTab).find('.nav-link').removeAttr('disabled');
                    $(nextTab).find('.nav-link').removeAttr('disabled');
                }
            });

            $('.prev-tab').click(function () {
                var currentTab = $(this).closest('.tab-pane');
                var prevTab = $(this).data('prev');
                $(prevTab).tab('show');
                $(currentTab).find('.nav-link').removeAttr('disabled');
            });

            function validateTab(tab) {
                var isValid = true;

                if (tab.attr('id') === 'general') {
                    var nameField = tab.find('[name="Name"]');
                    if (nameField.val().trim() === '') {
                        isValid = false;
                        alert('Please fill out the Name field.');
                    }
                } else if (tab.attr('id') === 'location') {
                }

                return isValid;
            }
        });
    </script>

}
