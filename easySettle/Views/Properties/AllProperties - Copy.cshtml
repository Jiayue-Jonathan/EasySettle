@model IEnumerable<easySettle.Models.Properties>

@{
    ViewData["Title"] = "Index";
}
<head>
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">
</head>
<h1>List of properties</h1>

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-9">
            <div class="map-container">
                <div id="map" style="height: 100%;"></div>
            </div>
        </div>
        <div class="col-lg-3">
            @Html.Partial("MainResults")
        </div>
    </div>
</div>
<script async
        src="https://maps.googleapis.com/maps/api/js?key=AIzaSyC-mAndBySKKnYRgtMiayzZ1eUr5cBj0Qg&callback=initMap">
</script>
<script>
    function initMap() {

        var map = new google.maps.Map(document.getElementById('map'), {
            center: { lat: 49.2075401, lng: -122.9038507 },
            zoom: 11
        });

        var properties = @Html.Raw(Json.Serialize(Model));

        var openInfoWindow = null; // Track the currently open InfoWindow

        for (var i = 0; i < properties.length; i++) {
            let marker = new google.maps.Marker({
                position: { lat: parseFloat(properties[i].lat), lng: parseFloat(properties[i].lon) },
                map: map,
                title: properties[i].name,
                animation: google.maps.Animation.DROP,
                icon: {
                    url: 'http://maps.google.com/mapfiles/ms/icons/blue-dot.png', // Blue marker icon
                    scaledSize: new google.maps.Size(40, 40), // Adjust the size as needed
                    origin: new google.maps.Point(0, 0),
                    anchor: new google.maps.Point(20, 40) // Position of the marker's tip relative to the bottom
                }
            });

            let infowindow = new google.maps.InfoWindow({
                content:
                    '<strong>'  + properties[i].name + '</strong><br>' +
                    'Price: $' + properties[i].rentPrice + '<br>' +
                    'Rooms: ' + properties[i].rooms + '<br>' +
                    'Street: ' + properties[i].streetName
            });

            marker.addListener('click', function () {
                // Close the currently open InfoWindow before opening a new one
                if (openInfoWindow) {
                    openInfoWindow.close();
                }

                infowindow.open(map, this);
                openInfoWindow = infowindow;
            });

            marker.addListener('animation_changed', function () {
                this.setAnimation(null);
            });
        }
    }
</script>
<script>
    function initMap() {

        var map = new google.maps.Map(document.getElementById('map'), {
            center: { lat: 49.2075401, lng: -122.9038507 },
            zoom: 11
        });

        var properties = @Html.Raw(Json.Serialize(Model));

        var openInfoWindow = null; // Track the currently open InfoWindow
        var bouncingMarker = null; // Track the currently bouncing marker

        for (var i = 0; i < properties.length; i++) {
            let marker = new google.maps.Marker({
                position: { lat: parseFloat(properties[i].lat), lng: parseFloat(properties[i].lon) },
                map: map,
                title: properties[i].name,
                icon: {
                    url: 'http://maps.google.com/mapfiles/ms/icons/blue-dot.png', // Blue marker icon
                    scaledSize: new google.maps.Size(40, 40),
                    origin: new google.maps.Point(0, 0),
                    anchor: new google.maps.Point(20, 40)
                }
            });

            let infowindow = new google.maps.InfoWindow({
                content: '<strong>' + properties[i].name + '</strong><br>' +
                    'Price: $' + properties[i].rentPrice + '<br>' +
                    'Rooms: ' + properties[i].rooms + '<br>' +
                    'Street: ' + properties[i].streetName
            });

            marker.addListener('click', function () {
                // Close the currently open InfoWindow before opening a new one
                if (openInfoWindow) {
                    openInfoWindow.close();
                }

                // Close bounce animation on the previously bouncing marker
                if (bouncingMarker && bouncingMarker !== this) {
                    bouncingMarker.setAnimation(null);
                }

                // Toggle the bounce animation
                if (this.getAnimation() !== null) {
                    this.setAnimation(null);
                    bouncingMarker = null;
                } else {
                    this.setAnimation(google.maps.Animation.BOUNCE);
                    bouncingMarker = this;
                }

                infowindow.open(map, this);
                openInfoWindow = infowindow;
            });
        }
    }
</script>



