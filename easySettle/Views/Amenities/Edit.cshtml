@model easySettle.ViewModel.AmenityViewModel


    @{
    ViewData["Title"] = "Edit";
}

<div class="container">
<h1>Edit</h1>
    <hr />
<h4>Amenities</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label">Name:</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group form-check">
                <input class="form-check-input" asp-for="IsDeleted" />
                <label class="form-check-label"> @Html.DisplayNameFor(model => model.IsDeleted)</label>
            </div>
            <div class="form-group form-check">
                <input class="form-check-input" asp-for="Enable" />
                <label class="form-check-label"> @Html.DisplayNameFor(model => model.Enable)</label>
            </div>
            
            
    
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
</div>