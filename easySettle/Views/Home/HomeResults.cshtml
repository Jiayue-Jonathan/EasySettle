 
<h2 class="text-primary">Search Results</h2>
 
<div class="property-list scrollable-list">
    <h4 class="text-success">Total items founds: @Model.PaginationInfo.TotalItems</h4>
    <ul class="list-group">
        @foreach (var property in Model.Properties)
        {
            <li class="list-group-item d-flex align-items-center">
                <img src="../uploadGallery/@property.PicFile1" alt="@property.Name" class="img-thumbnail mr-3" style="width: 340px; height: 210px;">
                  <div>
                    <h1 class="text-primary"><a href="@Url.Action("Details", "Properties", new { id = property.Id })">@property.Name</a></h1>
                    <h4 class="text-info">Street: @property.StreetName</h4>
                    <h4 class="text-info">ZipCode: @property.ZipCode</h4>
                    <h4 class="text-info">Description: @Html.Raw(property.Description.Length > 600 ? property.Description.Substring(0, 450) + "..." : property.Description)</h4>
                    <h4 class="text-info">Price: $@property.RentPrice</h4>
                    <a href="@Url.Action("Details", "Properties", new { id = property.Id })" class="btn btn-info"> See more details</a>
                </div>
            </li>
        }
    </ul>

    <div class="pagination justify-content-center mt-3">
        <nav aria-label="Page navigation">
            <ul class="pagination">
                @if (Model.PaginationInfo.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="@Url.Action("Search", new { page = Model.PaginationInfo.CurrentPage - 1, pageSize = Model.PaginationInfo.PageSize })"
                           aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>
                }
                @for (int i = 1; i <= Model.PaginationInfo.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PaginationInfo.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           href="@Url.Action("Search", new { page = i, pageSize = Model.PaginationInfo.PageSize })">@i</a>
                    </li>
                }

                @if (Model.PaginationInfo.CurrentPage < Model.PaginationInfo.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="@Url.Action("Search", new { page = Model.PaginationInfo.CurrentPage + 1, pageSize = Model.PaginationInfo.PageSize })"
                           aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>