@model easySettle.ViewModel.paginator.PropertyIndexResultViewModel

@{
    ViewData["Title"] = "Search Results";
}

<div class="search-wrap">
    <form asp-controller="Home" asp-action="Search" method="get">
        <input class="search-input-item" type="search" name="searchProperty" placeholder="Search by: Name, StreetName, ZipCode, Description" aria-label="Search" required>
        <button class="main-search-button" type="submit">Search</button>
    </form>
</div>

@if (Model == null || Model.Properties == null || !Model.Properties.Any())
{
    <p style="color: red;">No matching properties found.</p>
}
else
{
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="map-container">
                    <div id="map" style="height: 90%;"></div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <partial name="HomeResults" />
            </div>
        </div>
    </div>
}
<script async src="https://maps.googleapis.com/maps/api/js?key=AIzaSyC-mAndBySKKnYRgtMiayzZ1eUr5cBj0Qg&callback=initMap"></script>
<script>
    function initMap() {
        var map = new google.maps.Map(document.getElementById('map'), {
            center: { lat: 49.2075401, lng: -122.9038507 },
            zoom: 11
        });

        var properties = @Html.Raw(Json.Serialize(Model.Properties));

        var openInfoWindow = null;
        var bouncingMarker = null;

        for (var i = 0; i < properties.length; i++) {
            let marker = new google.maps.Marker({
                position: { lat: parseFloat(properties[i].lat), lng: parseFloat(properties[i].lon) },
                map: map,
                title: properties[i].name,
                icon: {
                    url: 'http://maps.google.com/mapfiles/ms/icons/blue-dot.png',
                    scaledSize: new google.maps.Size(40, 40),
                    origin: new google.maps.Point(0, 0),
                    anchor: new google.maps.Point(20, 40)
                }
            });

            let propertyDetailsLink = '@Url.Action("Details", "Properties", new { id = "propertyId" })'.replace("propertyId", properties[i].id);

            let infowindow = new google.maps.InfoWindow({
                content: '<strong>' + properties[i].name + '</strong><br>' +
                    'Price: $' + properties[i].rentPrice + '<br>' +
                    'Rooms: ' + properties[i].rooms + '<br>' +
                    'Street: ' + properties[i].streetName +
                    '<br><a href="' + propertyDetailsLink + '">View Property Details</a>'
            });

            marker.addListener('click', function () {
                if (openInfoWindow) {
                    openInfoWindow.close();
                }

                if (bouncingMarker && bouncingMarker !== this) {
                    bouncingMarker.setAnimation(null);
                }

                if (this.getAnimation() !== null) {
                    this.setAnimation(null);
                    bouncingMarker = null;
                } else {
                    this.setAnimation(google.maps.Animation.BOUNCE);
                    bouncingMarker = this;
                }

                infowindow.open(map, this);
                openInfoWindow = infowindow;
            });
        }
    }
</script>
